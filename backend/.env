# Liquid Charts API Configuration
LIQUID_API_URL=https://api.liquidcharts.com/v1
LIQUID_METRICS_BASE_URL=https://api.liquidcharts.com

# Basic Auth Configuration
# The DXAPI prefix is required for order placement and some account endpoints
LIQUID_BASIC_AUTH_HEADER=Authorization
LIQUID_BASIC_AUTH_PREFIX=DXAPI 

# Optional: Add your API keys if you have them
# LIQUID_API_KEY=your_api_key_here
# LIQUID_API_SECRET=your_api_secret_here

# Market Data
SIMULATE_FEED=true
POLYGON_SYMBOLS=^IXIC,AAPL,TSLA,MSFT,GOOGL,AMZN,NVDA,META,NFLX
