# Backend public base URLs
LIQUID_API_URL=https://api.liquidcharts.com/v1
LIQUID_METRICS_BASE_URL=https://api.liquidcharts.com

# Basic Auth header behavior
LIQUID_BASIC_AUTH_HEADER=Authorization
LIQUID_BASIC_AUTH_PREFIX=DXAPI 

# CORS: comma-separated origins allowed to call backend
# Example for local dev + mobile webview
FRONTEND_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,capacitor://localhost,ionic://localhost

# Market feed settings
SIMULATE_FEED=true
POLYGON_SYMBOLS=^IXIC,AAPL,TSLA,MSFT,GOOGL,AMZN,NVDA,META,NFLX

# Optional Polygon key for websocket feed
# POLYGON_API_KEY=your_polygon_key_here
